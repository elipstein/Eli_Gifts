# Local environment for running the generator. Copy to .env and fill in real values.
# .env is gitignored; in GitHub Actions these come from repo secrets instead.

# Anthropic API key for the generator (the web-search-enabled idea generation).
ANTHROPIC_API_KEY=sk-ant-...

# Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Supabase SECRET key (sb_secret_...). Server-side only — bypasses RLS.
# This is the modern replacement for the legacy service_role key.
# Never ship this to the browser; the client pages use the publishable key.
SUPABASE_SECRET_KEY=sb_secret_...
